{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: v7b Store + Enrich",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/debug_enrich_v7b.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false,
      "stopOnEntry": false
    }
  ]
}
